<a href="/">TOP</a> &gt; <a href="/ipa">IPA</a> &gt; <%= @ipa.filename %>
<div class="container">
<h2><%= @ipa.filename %></h2>

<p><%= @ipa.bundle_identifier %></p>

<p>Manifest URL: <code><%= "#{ENV['MDM_SERVER_BASE_URL']}/ipa/#{@ipa.url_encoded_filename}/manifest" %></code></p>

<h3>Manifest</h3>
<div class="card p-3 m-3">
<pre class="m-0"><%= ERB::Util.h(@ipa.metadata.as_manifest) %></pre>
</div>

<form action="/ipa/<%= @ipa.id %>/delete" method="post" onsubmit="return confirm('Are you sure you want to delete this IPA file?')">
  <button type="submit" class="btn btn-danger mt-2">Delete</button>
</form>
</div>
